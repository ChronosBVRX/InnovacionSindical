<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plantilla de Planilla Congresional Editable</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-blue: #234575;
            --secondary-teal: #49a5b0;
            --bg-light-grey: #f7f9fc;
            --text-dark: #333333;
            --card-border: #d1d9e6;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            margin: 0;
            padding: 0;
            background-color: var(--bg-light-grey);
            color: var(--text-dark);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .main-container {
            width: 1000px;
            background-color: #ffffff;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            position: relative;
            padding-bottom: 20px;
        }

        /* --- Header --- */
        .header {
            text-align: center;
            padding: 40px 20px;
            position: relative;
        }

        .header-logo {
            display: inline-block;
            margin-bottom: 15px;
        }

        /* Recreación del Logo CG */
        .cg-logo-wrapper {
            position: relative;
            display: inline-block;
        }
        .cg-logo-circles {
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .cg-circle {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            font-size: 40px;
            font-weight: 700;
            border: 4px solid #ffffff;
            position: relative;
        }
        .circle-c {
            background-color: var(--primary-blue);
            z-index: 1;
        }
        .circle-g {
            background-color: var(--secondary-teal);
            margin-left: -20px;
            z-index: 2;
        }
        .cg-logo-text {
            color: var(--primary-blue);
            font-weight: 400;
            font-size: 16px;
            margin-top: 5px;
            text-transform: uppercase;
        }
        .cg-logo-text b {
            font-weight: 700;
        }

        /* Decoraciones de Líneas y Puntos */
        .decor-top-right {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 150px;
            height: 20px;
            border-top: 2px solid var(--secondary-teal);
        }
        .decor-top-right::before, .decor-top-right::after {
            content: '';
            position: absolute;
            top: -5px;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background-color: var(--secondary-teal);
        }
        .decor-top-right::before { right: -5px; }
        .decor-top-right::after { right: 50px; }

        .decor-top-left-dots {
            position: absolute;
            top: 50px;
            left: 20px;
        }
        .decor-top-left-dots .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background-color: var(--secondary-teal);
            margin-bottom: 10px;
        }

        /* Títulos */
        .header h1 {
            color: var(--primary-blue);
            font-size: 36px;
            font-weight: 700;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .header h2 {
            color: var(--secondary-teal);
            font-size: 20px;
            font-weight: 600;
            margin: 5px 0 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* --- Representative Section --- */
        .representative-section {
            padding: 0 40px;
            margin-bottom: 30px;
        }

        .representative-banner {
            background-color: var(--primary-blue);
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px 30px;
            border-radius: 5px;
            position: relative;
        }

        .rep-info {
            display: flex;
            align-items: center;
        }

        .photo-placeholder {
            width: 80px;
            height: 80px;
            background-color: #f0f0f0;
            border-radius: 50%;
            border: 4px solid #ffffff;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            margin-right: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-size: cover;
            background-position: center;
        }

        .photo-placeholder svg {
            width: 100%;
            height: 100%;
            fill: #cccccc;
        }

        /* Pequeño logo CG en la silueta */
        .rep-silhoutte-logo {
            position: absolute;
            bottom: 5px;
            right: 5px;
            width: 20px;
            height: 20px;
            background-color: #ffffff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 700;
            color: var(--primary-blue);
            z-index: 3;
        }

        .rep-title-text {
            display: flex;
            flex-direction: column;
        }
        .rep-title {
            font-size: 16px;
            font-weight: 600;
            text-transform: uppercase;
            margin-bottom: 5px;
        }
        .rep-name {
            font-size: 30px;
            font-weight: 700;
            text-transform: uppercase;
        }

        /* Logo pequeño a la derecha */
        .rep-logo-small {
            display: flex;
            align-items: center;
            opacity: 0.9;
        }
        .rep-logo-small .cg-circle {
            width: 40px;
            height: 40px;
            font-size: 26px;
        }
        .rep-logo-small .cg-logo-text {
            color: #ffffff;
            margin-left: 10px;
            font-size: 12px;
            margin-top: 0;
        }

        /* --- Members Grid --- */
        .members-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            padding: 0 40px;
        }

        .member-card {
            background-color: #ffffff;
            border: 1px solid var(--card-border);
            padding: 15px;
            display: flex;
            align-items: center;
            border-radius: 5px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.03);
        }

        .member-photo {
            width: 60px;
            height: 60px;
            background-color: #f0f0f0;
            border-radius: 50%;
            overflow: hidden;
            margin-right: 15px;
            flex-shrink: 0;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            background-size: cover;
            background-position: center;
        }

        .member-photo svg {
            width: 100%;
            height: 100%;
            fill: #cccccc;
        }

        .member-info {
            display: flex;
            flex-direction: column;
            width: 100%;
        }

        .member-info span[contenteditable] {
            outline: none;
            display: block;
        }

        .member-name {
            font-weight: 700;
            color: var(--text-dark);
            font-size: 14px;
            margin-bottom: 3px;
        }

        .member-role {
            font-weight: 600;
            color: var(--primary-blue);
            font-size: 13px;
            margin-bottom: 2px;
        }

        .member-unit {
            font-weight: 400;
            color: var(--secondary-teal);
            font-size: 12px;
        }

        /* Decoración de puntos y líneas en la cuadrícula */
        .grid-decor-top-right {
            position: absolute;
            top: 50%;
            right: 0;
            transform: translateY(-50%);
            margin-right: -20px;
        }
        .grid-decor-top-right .decor-point {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background-color: var(--secondary-teal);
            margin-bottom: 8px;
        }

        /* --- Footer --- */
        .footer {
            margin-top: 40px;
            padding: 0 40px;
            position: relative;
        }

        .footer-banner {
            background-color: var(--secondary-teal);
            color: #ffffff;
            padding: 20px;
            border-radius: 5px;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .footer h3 {
            font-size: 20px;
            font-weight: 700;
            margin: 0;
            text-transform: uppercase;
        }
        .footer p {
            font-size: 16px;
            font-weight: 400;
            margin: 5px 0 0;
            text-transform: uppercase;
        }

        .vote-icon {
            position: absolute;
            right: 20px;
            bottom: 10px;
            width: 50px;
            height: 50px;
            opacity: 0.8;
        }

        /* --- Botón de Guardar --- */
        #save-button {
            position: fixed;
            top: 20px;
            left: 20px;
            padding: 10px 20px;
            background-color: var(--primary-blue);
            color: #ffffff;
            border: none;
            border-radius: 5px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
            z-index: 1000;
        }
        #save-button:hover {
            background-color: #1a3458;
        }

        /* Estilos para impresión (Ocultar botón) */
        @media print {
            #save-button, .decor-top-right, .decor-top-left-dots, .grid-decor-top-right {
                display: none;
            }
            body {
                background: #ffffff;
            }
            .main-container {
                box-shadow: none;
            }
        }
    </style>
</head>
<body>

    <button id="save-button" onclick="printPage()">Guardar Planilla (Imprimir/PDF)</button>

    <div class="main-container">

        <div class="header">
            <div class="cg-logo-wrapper">
                <div class="cg-logo-circles">
                    <div class="cg-circle circle-c">C</div>
                    <div class="cg-circle circle-g">G</div>
                </div>
                <div class="cg-logo-text" contenteditable><b>CG</b> CARLOS GUERRERO</div>
            </div>
            
            <div class="decor-top-right"></div>
            <div class="decor-top-left-dots">
                <div class="dot"></div>
                <div class="dot"></div>
            </div>
            
            <h1 contenteditable>PLANILLA CONGRESIONAL</h1>
            <h2 contenteditable>CONGRESO SECCIONAL ORDINARIO</h2>
        </div>

        <div class="representative-section">
            <div class="representative-banner">
                <div class="rep-info">
                    <div class="photo-placeholder" id="rep-photo" onclick="triggerFileUpload('rep-file-input')">
                        <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>
                        <div class="rep-silhoutte-logo">CG</div>
                    </div>
                    <input type="file" id="rep-file-input" accept="image/*" style="display: none;" onchange="handleFileUpload(this, 'rep-photo')">
                    
                    <div class="rep-title-text">
                        <span class="rep-title" contenteditable>REPRESENTANTE DE PLANILLA:</span>
                        <span class="rep-name" contenteditable>CARLOS GUERRERO</span>
                    </div>
                </div>
                
                <div class="rep-logo-small">
                    <div class="cg-logo-circles">
                        <div class="cg-circle circle-c">C</div>
                        <div class="cg-circle circle-g">G</div>
                    </div>
                    <div class="cg-logo-text" contenteditable><b>CG</b> CARLOS GUERRERO</div>
                </div>
            </div>
        </div>

        <div class="members-grid" id="members-grid">
            </div>
        <div class="grid-decor-top-right">
            <div class="decor-point"></div>
            <div class="decor-point"></div>
            <div class="decor-point"></div>
        </div>

        <div class="footer">
            <div class="footer-banner">
                <div>
                    <h3 contenteditable>¡ÚNETE A NUESTRA VISIÓN!</h3>
                    <p contenteditable>VOTA POR LA PLANILLA 'UNIÓN Y PROGRESO'</p>
                </div>
                <svg class="vote-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 14.5l-2.5 2.5-2.5-2.5m10 5.5h-10.5a1.5 1.5 0 01-1.5-1.5V11a1.5 1.5 0 011.5-1.5H23a1.5 1.5 0 011.5 1.5V19.5a1.5 1.5 0 01-1.5 1.5z"/><path d="M7 6v14a2 2 0 01-2 2H3a2 2 0 01-2-2V6a2 2 0 012-2h2a2 2 0 012 2z"/></svg>
            </div>
        </div>

    </div>

    <script>
        // Función para renderizar la cuadrícula de miembros
        function renderMembers() {
            const grid = document.getElementById('members-grid');
            const totalMembers = 9;
            const roles = ['VOCAL 1', 'SECRETARIO', 'TESORERO', 'CONSEJERO', 'VOCAL 2', 'CONSEJERO', 'VOCAL 3', 'CONSEJERO', 'VOCAL 4'];
            const units = ['A', 'B', 'C', 'D', 'E', 'F', '7', '8', '9'];

            // Siluetas SVG predeterminadas
            const maleSilhouette = `<svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>`;
            const femaleSilhouette = `<svg viewBox="0 0 24 24"><path d="M12 2c-5.52 0-10 4.48-10 10s4.48 10 10 10 10-4.48 10-10-4.48-10-10-10zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z" fill="#cccccc"/></svg>`; // Usando la misma para simplificar

            // Patrón de silueta de la imagen (H-H-M, M-H-M, H-M-H)
            const silhouttePattern = ['MALE', 'MALE', 'FEMALE', 'FEMALE', 'MALE', 'FEMALE', 'MALE', 'FEMALE', 'MALE'];

            for (let i = 0; i < totalMembers; i++) {
                const memberCard = document.createElement('div');
                memberCard.className = 'member-card';
                
                const photoId = `member-photo-${i}`;
                const fileInputId = `member-file-input-${i}`;
                
                const silhouette = (silhouttePattern[i] === 'FEMALE') ? maleSilhouette : maleSilhouette; // Mantenemos una silueta genérica o una para hombre y mujer. Por simplicidad usamos la misma.

                memberCard.innerHTML = `
                    <div class="member-photo" id="${photoId}" onclick="triggerFileUpload('${fileInputId}')">
                        ${silhouette}
                    </div>
                    <input type="file" id="${fileInputId}" accept="image/*" style="display: none;" onchange="handleFileUpload(this, '${photoId}')">
                    <div class="member-info">
                        <span class="member-name" contenteditable>NOMBRE DEL INTEGRANTE</span>
                        <span class="member-role" contenteditable>${roles[i]}</span>
                        <span class="member-unit" contenteditable>UNIDAD ${units[i]}</span>
                    </div>
                `;
                
                grid.appendChild(memberCard);
            }
        }

        // --- Funciones para la Carga de Fotos ---
        function triggerFileUpload(inputId) {
            document.getElementById(inputId).click();
        }

        function handleFileUpload(input, photoContainerId) {
            const file = input.files[0];
            const container = document.getElementById(photoContainerId);
            
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    container.style.backgroundImage = `url('${e.target.result}')`;
                    // Ocultar la silueta SVG predeterminada
                    const svg = container.querySelector('svg');
                    if(svg) svg.style.display = 'none';
                    // Para el representante, ocultar también el logo CG
                    const silLog = container.querySelector('.rep-silhoutte-logo');
                    if(silLog) silLog.style.display = 'none';
                }
                reader.readAsDataURL(file);
            }
        }

        // Función para imprimir la página (para guardar como PDF)
        function printPage() {
            window.print();
        }

        // Ejecutar al cargar la página
        window.onload = function() {
            renderMembers();
        };

    </script>
</body>
</html>
